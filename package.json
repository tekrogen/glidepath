{
  "name": "glidepath",
  "version": "1.1.0",
  "private": true,
  "description": "Glidepath — every card, one ledger, zero surprises. Credit-card cockpit by Tekrogen (Next.js, Prisma, NextAuth, shadcn/ui)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev -p 6014",
    "dev:https": "next dev --experimental-https -p 6014",
    "build": "next build",
    "start": "next start -p 6014",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@axe-core/playwright": "^4.12.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.539.0",
    "next": "16.2.10",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "plaid": "^41.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@types/node": "^22.19.11",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.28.0",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.5",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
