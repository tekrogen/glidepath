# =============================================================================
# Credit Card Manager — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# (.env is used because both Next.js and the Prisma CLI load it.)
# The demo works with NO external keys — just the database + auth secrets below.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (required)
# Matches docker-compose.yml. Start it with: docker compose up -d
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/credit_card_manager

# -----------------------------------------------------------------------------
# AUTH (required)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:6014
NEXTAUTH_SECRET=

# Demo login (demo@creditcardmanager.app / demo-password), seeded by `pnpm db:seed`.
# ⚠️ Disable BOTH flags before deploying with real user data.
ENABLE_DEMO_AUTH=true
NEXT_PUBLIC_ENABLE_DEMO_AUTH=true

# Emails promoted to ADMIN on first sign-in (comma-separated). ADMIN is a
# platform role — it has no access to financial data.
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (optional — sign-in providers appear only when configured)
# Google: https://console.cloud.google.com/apis/credentials
#   Redirect URI: http://localhost:6014/api/auth/callback/google
# GitHub: https://github.com/settings/developers
#   Callback URL: http://localhost:6014/api/auth/callback/github
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# PLAID (optional for the demo; required to link real/sandbox accounts)
# Get your keys: https://dashboard.plaid.com/team/keys
# Sandbox test login inside Plaid Link: user_good / pass_good
# See SETUP.md for the full walkthrough.
# -----------------------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
# "sandbox" or "production"
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
# Must be registered in the Plaid dashboard (Allowed redirect URIs)
PLAID_REDIRECT_URI=http://localhost:6014/connect-account
# Public HTTPS URL for webhooks (e.g. your deployment or a tunnel); optional locally
PLAID_WEBHOOK_URL=
# Encrypts Plaid access tokens at rest. Generate with: openssl rand -hex 32
PLAID_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# AI INSIGHTS (optional — the dashboard shows curated mock insights when off)
# -----------------------------------------------------------------------------
ENABLE_AI_INSIGHTS=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# -----------------------------------------------------------------------------
# MAINTENANCE (optional)
# Protects /api/cron/plaid-cleanup. Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=
