# ==============================================================================
# OS-Specific Files
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

# ==============================================================================
# Editor / IDE Files
# ==============================================================================

# JetBrains / IntelliJ IDEA
.idea/
.idea/vcs.xml
!.idea/codeStyles/
!.idea/runConfigurations/
*.iml
*.iws
*.ipr
.idea_modules/
atlassian-ide-plugin.xml

# JetBrains AI Assistant (local, per-machine)
.ai/
.aiignore

# AWS User-specific
.idea/**/aws.xml

# Generated files
.idea/**/contentModel.xml

# Sensitive or high-churn files
.idea/**/dataSources/
.idea/**/dataSources.ids
.idea/**/dataSources.local.xml
.idea/**/sqlDataSources.xml
.idea/**/dynamic.xml
.idea/**/uiDesigner.xml
.idea/**/dbnavigator.xml

# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.vscode-test

# Vim
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ==============================================================================
# Environment Variables & Secrets
# ==============================================================================

# Ignore all .env* files at any location except .env.example
**/.env*
!.env.example
!**/.env.example

# Security-sensitive files
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.pb
*.secret
secrets/
*.private
id_rsa*
*.p8
*.keychain

