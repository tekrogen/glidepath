// Prisma schema — Credit Card Manager
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          UserRole      @default(USER)
  status        AccountStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts         Account[]
  sessions         Session[]
  userAccounts     UserAccount[]
  transactions     Transaction[]
  budgets          Budget[]
  insights         AIInsight[]
  preferences      UserPreferences?
  auditLogs        AuditLog[]
  plaidItems       PlaidItem[]
  notifications    Notification[]
  householdMembers HouseholdMember[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Financial models
model UserAccount {
  id            String      @id @default(cuid())
  userId        String
  name          String
  type          AccountType
  balance       Decimal     @default(0) @db.Decimal(12, 2)
  currency      String      @default("USD")
  institution   String
  accountNumber String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  creditCards  CreditCard[]

  @@index([userId])
}

model Transaction {
  id                  String            @id @default(cuid())
  accountId           String
  userId              String
  amount              Decimal           @db.Decimal(12, 2)
  description         String
  originalDescription String? // For banks that provide both
  category            String
  subcategory         String?
  merchant            String?
  date                DateTime
  time                String? // Some banks provide separate time
  type                TransactionType
  status              TransactionStatus @default(COMPLETED)
  tags                String[]
  location            Json?

  // Import tracking fields
  importSource String? @unique // e.g., "plaid_<transaction_id>" — globally unique; enforces sync idempotency
  importBatch  String? // Track which import batch this came from
  originalData Json? // Store original raw data for debugging

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account UserAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([accountId])
  @@index([category])
  @@index([importBatch])
}

model Budget {
  id        String       @id @default(cuid())
  userId    String
  name      String
  category  String
  amount    Decimal      @db.Decimal(12, 2)
  spent     Decimal      @default(0) @db.Decimal(12, 2)
  period    BudgetPeriod
  startDate DateTime
  endDate   DateTime
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period, isActive])
}

model AIInsight {
  id          String      @id @default(cuid())
  userId      String
  type        InsightType
  title       String
  description String
  impact      Impact
  category    String
  source      String?     @default("spending")
  actionable  Boolean     @default(false)
  isRead      Boolean     @default(false)
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

// Category system for transaction classification
model Category {
  id        String       @id @default(cuid())
  name      String       @unique
  type      CategoryType
  parentId  String?
  level     Int          @default(0) // 0 = main category, 1 = subcategory
  keywords  String[] // Keywords for auto-categorization
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  @@index([type, isActive])
  @@index([parentId])
}

// User preferences (one-to-one with User)
model UserPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique
  theme                String   @default("system")
  displayCurrency      String   @default("USD") // ISO 4217, for aggregates/UI
  compactMode          Boolean  @default(false)
  emailNotifications   Boolean  @default(true)
  browserNotifications Boolean  @default(false)
  bio                  String?
  location             String?
  socialLinks          Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Audit log for tracking user actions
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  details   String?  @db.Text
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
}

// In-app notifications — persisted attention items (issue #25).
// One row per (user, occurrence): the dedupeKey unique makes the
// write-on-read sync idempotent; rows are never updated by the sync.
enum NotificationType {
  PROMO_EXPIRED
  PROMO_ENDING_SOON
  HIGH_UTILIZATION
  DUE_SOON
  SYNC_FAILED
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  entityRef   String? // "card:<id>" — never a lastFour
  dedupeKey   String // stable occurrence identity — controls re-notification
  title       String
  body        String
  href        String?
  createdAt   DateTime         @default(now())
  readAt      DateTime?
  dismissedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}

// Plaid integration
enum PlaidItemStatus {
  ACTIVE
  PENDING_EXPIRATION
  LOGIN_REQUIRED
  REVOKED
  DISCONNECTED
}

model PlaidItem {
  id               String          @id @default(cuid())
  userId           String
  accessToken      String // AES-256-GCM encrypted
  itemId           String          @unique
  institutionId    String?
  institutionName  String?
  status           PlaidItemStatus @default(ACTIVE)
  consentExpiresAt DateTime?
  cursor           String? // Plaid transactions sync cursor
  lastSyncedAt     DateTime?
  syncInProgress   Boolean         @default(false) // Per-item sync lock (compare-and-swap)
  syncStartedAt    DateTime? // When the current sync acquired the lock (stale-lock recovery)
  errorCode        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Enums
enum UserRole {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  LOAN
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum InsightType {
  OPPORTUNITY
  WARNING
  TREND
  TIP
}

enum Impact {
  LOW
  MEDIUM
  HIGH
}

enum CategoryType {
  INCOME
  EXPENSE
}

// ─── Glidepath card domain (Blueprint Level 6, Phase 1) ─────────────────────
// Money: integer minor units (BigInt cents) + ISO currency (EDR-008).
// APRs: integer basis points — 2274 = 22.74%.
// Authorization resolves through household membership (EDR-014).

enum CardLifecycle {
  ACTIVE
  FROZEN
  ARCHIVED
}

enum CardSyncStatus {
  MANUAL
  SYNCED
  SYNC_PENDING
  SYNC_FAILED
  DISCONNECTED
}

enum CardAttribution {
  MEMBER
  SHARED
}

enum CardType {
  PERSONAL
  BUSINESS
}

enum FieldSource {
  PLAID
  MANUAL
  UNKNOWN
}

enum PromoStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum HouseholdRole {
  OWNER
  MEMBER
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           HouseholdMember[]
  cards             CreditCard[]
  financialAccounts FinancialAccount[]
  paymentIntents    PaymentIntent[]
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  displayName String // "Marti", "Bob" — label-only members have no userId
  userId      String? // set when the member becomes a real login (additive path, EDR-014)
  role        HouseholdRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  household  Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  ownedCards CreditCard[] @relation("CardOwner")

  @@unique([householdId, displayName])
  @@index([userId])
}

model CreditCard {
  id            String          @id @default(cuid())
  householdId   String
  ownerMemberId String? // null ⇒ shared household card
  attribution   CardAttribution @default(SHARED)

  cardName  String
  lastFour  String? // text: preserves leading zeros; NEVER a key (duplicates exist)
  issuer    String // display name, e.g. "Chase"
  issuerKey String? // logo/swatch lookup key
  network   String?
  cardType  CardType @default(PERSONAL)
  currency  String   @default("USD") // ISO 4217 billing currency

  creditLimitMinor      BigInt? // null ⇒ utilization undefined
  currentBalanceMinor   BigInt  @default(0) // positive amount owed
  statementBalanceMinor BigInt?
  regularAprBps         Int? // 2274 = 22.74%
  statementCloseDay     Int? // 1-31
  paymentDueDay         Int? // 1-31
  paymentDueTimeZone    String  @default("America/New_York")
  minimumPaymentMinor   BigInt?
  paymentNote           String? // free text by design: "$350/month", "Statement Amt"

  lifecycle    CardLifecycle  @default(ACTIVE)
  syncStatus   CardSyncStatus @default(MANUAL)
  lastSyncedAt DateTime?

  // Field provenance → estimated-vs-confirmed UI states
  limitSource   FieldSource @default(UNKNOWN)
  aprSource     FieldSource @default(UNKNOWN)
  minimumSource FieldSource @default(UNKNOWN)

  userAccountId String? // optional aggregator link
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  household         Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownerMember       HouseholdMember?     @relation("CardOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  userAccount       UserAccount?         @relation(fields: [userAccountId], references: [id], onDelete: SetNull)
  promoPeriods      PromoPeriod[]
  paymentIntents    PaymentIntent[]
  scheduledPayments ScheduledPayment[]
  statements        Statement[]
  autopayLink       ProviderAutopayLink?

  @@index([householdId])
}

// Inside the CreditCard aggregate — edited with the card (EDR-017).
model PromoPeriod {
  id                    String      @id @default(cuid())
  cardId                String
  promoAprBps           Int         @default(0)
  regularAprBpsAfter    Int?
  startsOn              DateTime?   @db.Date
  endsOn                DateTime    @db.Date
  shelteredBalanceMinor BigInt      @default(0)
  status                PromoStatus @default(ACTIVE)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ── Payment domain (Phase 3, EDR-010) ────────────────────────────────────────
// Record-only: these tables capture user intent and tracking state. Nothing
// here executes, initiates, or reconciles a real payment (Level 0 boundary).

enum FinancialAccountType {
  CHECKING
  SAVINGS
  OTHER
}

enum PaymentIntentStatus {
  DRAFT
  SUBMITTED
  EXPIRED
}

enum ScheduledPaymentStatus {
  SCHEDULED
  DONE
  SKIPPED
  CANCELED
}

// Funding-account metadata only — names where a payment will come from.
// No balances and no sync: it is a reference label, not a ledger.
model FinancialAccount {
  id          String               @id @default(cuid())
  householdId String
  name        String
  institution String?
  accountType FinancialAccountType @default(CHECKING)
  lastFour    String? // text: preserves leading zeros; NEVER a key
  currency    String               @default("USD") // ISO 4217
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  household         Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paymentIntents    PaymentIntent[]
  scheduledPayments ScheduledPayment[]

  @@index([householdId])
}

// Expiring stepper draft: DRAFT (editable) → SUBMITTED (immutable) | EXPIRED (cron).
// Fields stay optional while the draft is being assembled; the confirm step
// validates completeness before recording the ScheduledPayment.
model PaymentIntent {
  id               String              @id @default(cuid())
  householdId      String
  cardId           String?
  fundingAccountId String?
  amountMinor      BigInt?
  currency         String              @default("USD")
  scheduledFor     DateTime?           @db.Date
  note             String?
  status           PaymentIntentStatus @default(DRAFT)
  expiresAt        DateTime
  submittedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  household        Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  card             CreditCard?       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fundingAccount   FinancialAccount? @relation(fields: [fundingAccountId], references: [id], onDelete: SetNull)
  scheduledPayment ScheduledPayment?

  @@index([householdId])
  @@index([status, expiresAt]) // intent-expiry cron scan
}

// Record-only planned payment: SCHEDULED → DONE | SKIPPED | CANCELED.
model ScheduledPayment {
  id               String                 @id @default(cuid())
  cardId           String
  fundingAccountId String?
  intentId         String?                @unique // one payment per confirmed intent — DB backstop for idempotent confirm
  amountMinor      BigInt
  currency         String                 @default("USD")
  scheduledFor     DateTime               @db.Date
  status           ScheduledPaymentStatus @default(SCHEDULED)
  resolvedAt       DateTime? // set when status leaves SCHEDULED
  note             String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  card           CreditCard        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fundingAccount FinancialAccount? @relation(fields: [fundingAccountId], references: [id], onDelete: SetNull)
  intent         PaymentIntent?    @relation(fields: [intentId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([scheduledFor])
}

// First-class immutable statement record (EDR-015): no update path exists in
// the service layer, hence no updatedAt. Discrepancies vs the card's balance
// become attention items — never auto-mutation. Document ingest is out of
// scope (Level 0 boundary); statement data arrives as values, not files.
model Statement {
  id                    String      @id @default(cuid())
  cardId                String
  periodStart           DateTime?   @db.Date
  closingDate           DateTime    @db.Date
  dueDate               DateTime?   @db.Date
  statementBalanceMinor BigInt
  minimumDueMinor       BigInt?
  currency              String      @default("USD") // ISO 4217
  source                FieldSource @default(MANUAL)
  createdAt             DateTime    @default(now())

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, closingDate]) // one record per statement close; ingestion idempotency backstop
}

// Where autopay actually lives (EDR-016: provider link-out, no in-app
// scheduler). autopayActive feeds the PAY/AUTO chip on upcoming payments.
model ProviderAutopayLink {
  id            String   @id @default(cuid())
  cardId        String   @unique // one autopay arrangement per card
  providerUrl   String? // issuer payment page for link-out
  autopayActive Boolean  @default(false) // user confirmed autopay is set up at the issuer
  note          String? // free text by design: "minimum on due date", "$350/month"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}
